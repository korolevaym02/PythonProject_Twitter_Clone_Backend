# Twitter Clone Backend - Конфигурация окружения
# Копируйте в .env и редактируйте при необходимости

# PostgreSQL подключение (docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://twitter:twitterpass@db:5432/twitter

# Секретный ключ
SECRET_KEY=your-super-secret-key-change-in-production-2026

# Максимальная длина твита
MAX_TWEET_LENGTH=280

# Путь к медиа файлам
MEDIA_PATH=./media

# Размер медиа (байты)
MAX_MEDIA_SIZE=10485760

# Разрешенные типы файлов
ALLOWED_MEDIA_TYPES=image/jpeg,image/png,image/webp

# Логирование
LOG_LEVEL=info

# Docker флаг
DOCKER_ENV=true